# Copy to .env and set values. DO NOT commit .env to GitHub (secrets).
# For Render Web Service: set these in Dashboard → Environment instead.

# Optional: Public app URL for canonical links and sitemap (defaults to VITE_BACKEND_URL if set at build)
# VITE_APP_URL=https://unipilot.onrender.com

# Server (Node) reads this. Used for AI coach, tashkeel, and AI text-to-speech. Get key at https://console.groq.com
GROQ_API_KEY=

# Unsplash: topic images for presentation slides. Get Access Key at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Server (Node) reads this. Required in production (min 32 chars). No default in production.
JWT_SECRET=

# Optional: Sentry DSN for frontend error tracking. Set in production for buyer.
VITE_SENTRY_DSN=

# In production, comma-separated origins for CORS (e.g. https://unipilot.onrender.com). Empty = allow same-origin.
FRONTEND_ORIGIN=

# PostgreSQL connection string (required for the app). Example:
# postgresql://USER:PASSWORD@localhost:5432/unipilot
# For cloud: use the URL from your provider (Neon, Supabase, Render, etc.)
DATABASE_URL=
