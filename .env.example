# Copy to .env and set values. DO NOT commit .env to GitHub (secrets).
# For Render: set these in Dashboard → Environment (same names). Build-time: VITE_BACKEND_URL.
# دليل النشر على Render بالعربية: docs/RENDER_DEPLOY_AR.md

# Optional: Public app URL for canonical links and sitemap (defaults to VITE_BACKEND_URL if set at build)
# VITE_APP_URL=https://unipilot.onrender.com
# Optional: Backend runtime public URL used for Stripe return/success/cancel defaults
APP_URL=

# Server (Node) reads this. Used for AI coach, tashkeel, and AI text-to-speech. Get key at https://console.groq.com
GROQ_API_KEY=

# Unsplash: topic images for presentation slides. Get Access Key at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# Server (Node) reads this. Required in production (min 32 chars). No default in production.
JWT_SECRET=

# Optional: Sentry DSN for frontend error tracking. Set in production for buyer.
VITE_SENTRY_DSN=

# In production, comma-separated origins for CORS (e.g. https://unipilot.onrender.com). Empty = allow same-origin.
FRONTEND_ORIGIN=

# PostgreSQL connection string (required for the app). Example:
# postgresql://USER:PASSWORD@localhost:5432/unipilot
# For cloud: use the URL from your provider (Neon, Supabase, Render, etc.)
DATABASE_URL=

# ----- SaaS / Billing (Stripe) -----
# Full guide (Arabic): docs/STRIPE_SETUP_AR.md
# Stripe secret key (required for checkout/portal)
STRIPE_SECRET_KEY=
# Webhook signing secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=
# Publishable key for frontend
STRIPE_PUBLISHABLE_KEY=
# Price IDs for Pro and Student plans (create in Stripe Products)
STRIPE_PRO_PLAN_PRICE_ID=
STRIPE_STUDENT_PLAN_PRICE_ID=

# ----- AI usage limits -----
# Free tier: max AI requests per user per month (default 50)
AI_FREE_MONTHLY_LIMIT=50

# ----- Observability -----
# Backend error tracking (Sentry)
SENTRY_DSN=
# Product analytics (PostHog)
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ----- Optional -----
# Redis URL for cache/queues (leave empty to disable)
REDIS_URL=
# Log level: error | warn | info | debug
LOG_LEVEL=info
